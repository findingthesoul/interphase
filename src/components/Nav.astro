---
interface Props {
  current?: string;
}
const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header class="site-nav">
  <div class="site-nav-inner">
    <a class="brand" href={`${base}/`} aria-label="Interphase — home">
      <img class="brand-wordmark" src={`${base}/wordmark.svg`} alt="Interphase" width="110" height="42" />
    </a>
    {current ? (
      <>
        <span class="nav-current">{current}</span>
        <a class="nav-link" href={`${base}/`}>← Index</a>
      </>
    ) : (
      <nav class="nav-meta" aria-label="Primary">
        <a class="nav-link" href={`${base}/00-summary`}>00 · Summary</a>
        <a class="nav-link" href={`${base}/01-concept`}>01 · Concept</a>
        <a class="nav-link" href={`${base}/02-framework`}>02 · Framework</a>
        <a class="nav-link" href={`${base}/03-product`}>03 · Product</a>
        <a class="nav-link" href={`${base}/04-chaperone`}>04 · Chaperone</a>
        <a class="nav-link" href={`${base}/05-organisation`}>05 · Organisation</a>
      </nav>
    )}
  </div>
</header>

<script is:inline>
  // Home page only: nav wordmark is hidden until the hero wordmark scrolls
  // past the fixed nav. The Nav component is rendered before the hero in the
  // DOM, so we wait for DOMContentLoaded before querying for the hero element.
  (function () {
    function init() {
      var heroWordmark = document.querySelector('.home-hero-wordmark');
      var navWordmark = document.querySelector('.brand-wordmark');
      if (!navWordmark) return;
      if (!heroWordmark) return; // Inner page — leave nav logo visible.

      // Hide immediately so there is no flash at first paint.
      navWordmark.classList.add('is-hidden');

      var navHeight = window.innerWidth <= 720 ? 64 : 82;
      var io = new IntersectionObserver(
        function (entries) {
          var entry = entries[0];
          if (entry.isIntersecting) {
            navWordmark.classList.add('is-hidden');
          } else {
            navWordmark.classList.remove('is-hidden');
          }
        },
        { threshold: 0, rootMargin: '-' + navHeight + 'px 0px 0px 0px' }
      );
      io.observe(heroWordmark);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
