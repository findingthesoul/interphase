---
interface Props {
  size?: number;
  class?: string;
}
const { size = 22, class: className = '' } = Astro.props;
---

<svg
  class={`cell-mark ${className}`}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <circle cx="12" cy="12" r="10.5" stroke="currentColor" stroke-width="1.25" />
  <ellipse cx="12" cy="12" rx="5.5" ry="5.5" stroke="currentColor" stroke-width="0.9" stroke-dasharray="2 2" />
  <circle cx="12" cy="12" r="1.6" fill="currentColor" />
</svg>
